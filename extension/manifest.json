{
  "manifest_version": 3,
  "name": "Tidal Now Playing",
  "version": "0.1.0",
  "description": "Forwards Tidal web playback state to the local Tidal Now Playing companion server.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "http://127.0.0.1/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://listen.tidal.com/*",
        "https://tidal.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
